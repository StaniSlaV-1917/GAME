# Скопируйте этот файл в .env и заполните свои значения

# URL Laravel API (без слэша в конце)
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Корневой URL бэкенда для медиафайлов (storage, img и пр.)
# Локально:   http://127.0.0.1:8000
# На хостинге: https://api.yourdomain.com
VITE_MEDIA_BASE_URL=http://127.0.0.1:8000
